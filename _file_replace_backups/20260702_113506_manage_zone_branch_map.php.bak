<?php if ($error): ?>
<div class="alert error no-print"><?= h($error) ?></div>
<?php endif; ?>

<div class="card no-print">
<form method="post">

<input type="hidden" name="id" value="<?= h($editData['id'] ?? '') ?>">

<table>
<tr>
<td>Zone Name</td>
<td><input type="text" name="zone_name" value="<?= h($editData['zone_name'] ?? '') ?>"></td>
</tr>

<tr>
<td>Branch Name</td>
<td><input type="text" name="branch_name" value="<?= h($editData['branch_name'] ?? '') ?>"></td>
</tr>

<tr>
<td>Branch Code</td>
<td><input type="text" name="branch_code" value="<?= h($editData['branch_code'] ?? '') ?>"></td>
</tr>

<tr>
<td>Status</td>
<td>
<select name="status">
    <option value="1" <?= (($editData['status'] ?? 1) == 1) ? 'selected' : '' ?>>Active</option>
    <option value="0" <?= (($editData['status'] ?? 1) == 0) ? 'selected' : '' ?>>Inactive</option>
</select>
</td>
</tr>

<tr>
<td colspan="2">
<button type="submit" class="btn btn-save"><?= $editData ? 'Update' : 'Save' ?></button>
<?php if ($editData): ?>
<a href="manage_zone_branch_map.php" class="btn" style="background:#6c757d; color:#fff; margin-left: 10px;">Cancel</a>
<?php endif; ?>
</td>
</tr>

</table>
</form>
</div>

<div class="card">
    <div class="top-controls">
        <h4>Branch List</h4>
        <div class="no-print">
            <input type="text" id="searchInput" class="search-box" placeholder="Search by Zone, Branch or Code...">
            <button onclick="window.print()" class="btn btn-print">Print List</button>
        </div>
    </div>

<table id="branchTable">
<tr>
<th>SL</th>
<th>Zone</th>
<th>Branch</th>
<th>Code</th>
<th>Status</th>
<th class="no-print">Action</th>
</tr>

<?php if ($list && $list->num_rows > 0): $sl=1; while($r=$list->fetch_assoc()): ?>
<tr>
<td><?= $sl++ ?></td>
<td><?= h($r['zone_name']) ?></td>
<td><?= h($r['branch_name']) ?></td>
<td><?= h($r['branch_code']) ?></td>
<td><?= $r['status'] ? 'Active' : 'Inactive' ?></td>
<td class="no-print">
<a href="?edit=<?= $r['id'] ?>" class="btn btn-edit">Edit</a>
<a href="?delete=<?= $r['id'] ?>" class="btn btn-del"
   onclick="return confirm('Are you sure you want to delete this branch?')">Delete</a>
</td>
</tr>
<?php endwhile; endif; ?>

</table>
</div>

<script>
document.getElementById('searchInput').addEventListener('keyup', function() {
    let filter = this.value.toLowerCase();
    let rows = document.querySelectorAll('#branchTable tr:not(:first-child)');
    let visibleCount = 0;

    rows.forEach(row => {
        let cells = row.getElementsByTagName('td');
        if (cells.length > 0) {
            let searchContent = "";
            // Combine all cell content except the first (SL number) to search against
            for (let i = 1; i < cells.length; i++) {
                searchContent += cells[i].textContent.toLowerCase() + " ";
            }
            
            if (searchContent.includes(filter)) {
                row.style.display = '';
                visibleCount++;
                cells[0].textContent = visibleCount;
            } else {
                row.style.display = 'none';
            }
        }
    });
});
</script>

</body>
</html>